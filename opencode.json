{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    "public/AGENTS.md",
    "routes/AGENTS.md",
    ".opencode/memory/project.md",
    ".opencode/memory/decisions.md"
  ],
  "agent": {
    "tester": {
      "description": "Executa testes no servidor CyberPDV e reporta PASS/FAIL",
      "mode": "subagent",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "deny",
        "write": "deny",
        "bash": "allow"
      }
    },
    "debugger": {
      "description": "Investiga bugs no codigo sem modificar arquivos",
      "mode": "subagent",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "deny",
        "write": "deny",
        "bash": "allow"
      }
    },
    "spec-reviewer": {
      "description": "Verifica implementacao contra spec em specs/",
      "mode": "subagent",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "deny",
        "write": "deny",
        "bash": "allow"
      }
    }
  },
  "permission": {
    "edit": "ask",
    "bash": "ask",
    "webfetch": "ask"
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  }
}
